# ── Database ──────────────────────────────────────────────
# Same Postgres database the Dumbledore bot itself uses.
DATABASE_URL=postgres://user:password@host:5432/dumbledore

# ── Discord application (discord.com/developers/applications) ─
# Same app as the bot. Add DISCORD_REDIRECT_URI below to
# "OAuth2 → Redirects" in the Discord developer portal.
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-id
DISCORD_CLIENT_SECRET=your-oauth2-client-secret
DISCORD_REDIRECT_URI=http://localhost:3001/auth/callback

# The single guild this dashboard manages.
GUILD_ID=1515579416074387507

# ── Access control ───────────────────────────────────────────
# Anyone holding either role (or the Administrator permission,
# or the server owner) can sign in. Defaults match constants.ts.
ADMIN_ROLE_ID=1515683964977676338
BOT_MANAGER_ROLE_ID=1516270120832335962

# ── Session ───────────────────────────────────────────────────
# Random long string used to sign login sessions.
SESSION_SECRET=change-this-to-a-long-random-string
SESSION_TTL_HOURS=12

# ── Server ────────────────────────────────────────────────────
PORT=3001
# Set to your deployed dashboard URL in production (no trailing slash)
PUBLIC_URL=http://localhost:3001
NODE_ENV=development
